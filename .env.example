# ============================================================
# AutoForge - 环境变量模板 (Environment Variable Template)
# ============================================================
# 复制此文件为 .env 并填入你的配置
# ⚠️  .env 文件已被 .gitignore 排除，不会被推送到仓库

# --- LLM 配置（必需） ---
AUTOFORGE_LLM_API_KEY=sk-your-api-key-here
AUTOFORGE_LLM_BASE_URL=https://api.deepseek.com
AUTOFORGE_MODEL_NAME=deepseek-chat

# --- GitHub Token（可选，用于查重提速） ---
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 以下配置由 config.yaml 管理，无需在此设置 ---
# OUTPUT_PATH=./output
# MAX_RETRIES=8
# LOG_LEVEL=INFO
